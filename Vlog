admin/config.yml
backend:
  name: github
  repo: MarkMusicEducation/music-education-lab
  branch: main

media_folder: images

locale: ja

collections:
  - name: news
    label: お知らせ・ブログ
    folder: _posts
    create: true
    slug: "{{year}}-{{month}}-{{day}}-{{slug}}"
    fields:
      - {label: タイトル, name: title, widget: string}
      - {label: 投稿日, name: date, widget: datetime}
      - {label: カテゴリ, name: category, widget: select, options: [海外研究紹介, 活動報告, セミナー案内, コラム]}
      - {label: 本文, name: body, widget: markdown}
